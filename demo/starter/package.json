{
  "name": "slidev-demo",
  "private": true,
  "scripts": {
    "build": "slidev build",
    "dev:cleanup": "bash dev-cleanup.sh",
    "dev:cleanup:dry": "bash dev-cleanup.sh --dry-run",
    "dev": "nodemon -w '../../packages/slidev/dist/*.mjs' --exec \"slidev ./slides.md --open=false --log=info --inspect --port=3282\"",
    "static": "pnpm build && cd dist && npx -y serve --no-clipboard -l 3283 .",
    "static:serve": "cd dist && npx -y serve --no-clipboard -l 3283 .",
    "static:dev": "SLIDEV_DEV_STATIC=1 nodemon -w '../../packages/slidev/dist/*.mjs' --exec \"slidev ./slides.md --open=false --log=info --inspect --port=3283\"",
    "export": "slidev export",
    "export-notes": "slidev export-notes"
  },
  "devDependencies": {
    "@slidev/cli": "workspace:*",
    "@slidev/theme-default": "catalog:themes",
    "@slidev/theme-seriph": "catalog:themes",
    "nodemon": "catalog:dev",
    "vue": "catalog:frontend"
  }
}
